{
  "name": "@repo/nestjs-base",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal NestJS base utilities to scaffold typed reusable modules.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./*": "./src/*"
  },
  "scripts": {
    "prettify": "prettier . --write --no-error-on-unmatched-pattern",
    "format": "bun run prettify",
    "format:check": "prettier . --check --no-error-on-unmatched-pattern",
    "lint": "bunx eslint src",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@nestjs/common": "catalog:api:nest"
  },
  "devDependencies": {
    "@repo/config-eslint": "*",
    "@repo/config-prettier": "*",
    "@repo/config-typescript": "*",
    "@repo/config-vitest": "*",
    "@types/node": "catalog:build",
    "eslint": "catalog:linting",
    "prettier": "catalog:linting",
    "typescript": "catalog:build",
    "vitest": "catalog:testing",
    "@vitest/coverage-v8": "catalog:testing"
  },
  "peerDependencies": {
    "@nestjs/common": "catalog:api:nest"
  }
}
